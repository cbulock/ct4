---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryList from '../components/EntryList.astro';
import {
	getEntriesForYear,
	getEntryYears,
} from '../lib/content';

export const getStaticPaths = async () =>
	(await Promise.all(
		(await getEntryYears()).map(async (year) => ({
		params: { year },
		props: {
			entries: await getEntriesForYear(year),
			year,
		},
		})),
	));

const { entries, year } = Astro.props;
---

<BaseLayout title={`${year} - Cameron's Thoughts`}>
	<cindor-stack gap="4">
		<h1 class="surface-heading">{year}</h1>
		<EntryList entries={entries} />
	</cindor-stack>
</BaseLayout>
