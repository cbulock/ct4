---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryList from '../components/EntryList.astro';
import {
	getEntriesForYear,
	getEntryYears,
} from '../lib/content';

export const getStaticPaths = () =>
	getEntryYears().map((year) => ({
		params: { year },
		props: {
			entries: getEntriesForYear(year),
			year,
		},
	}));

const { entries, year } = Astro.props;
---

<BaseLayout title={`${year} - Cameron's Thoughts`}>
	<div class="flow-stack" data-gap="4">
		<h1 class="surface-heading">{year}</h1>
		<EntryList entries={entries} />
	</div>
</BaseLayout>
