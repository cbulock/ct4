---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryList from '../../components/EntryList.astro';
import {
	getCategories,
	getEntriesForCategory,
} from '../../lib/content';

export const getStaticPaths = () =>
	getCategories().map((category) => ({
		params: { categoryBasename: category.basename },
		props: {
			category,
			entries: getEntriesForCategory(category.id),
		},
	}));

const { category, entries } = Astro.props;
---

<BaseLayout title={`${category.label} - Cameron's Thoughts`}>
	<div class="flow-stack" data-gap="4">
		<h1 class="surface-heading">{category.label}</h1>
		<EntryList entries={entries} />
	</div>
</BaseLayout>
