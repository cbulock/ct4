---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
	getCategories,
	getEntriesForCategory,
	getEntriesForYear,
	getEntryYears,
} from '../lib/content';

const years = getEntryYears().slice().reverse();
const categories = getCategories()
	.slice()
	.sort((left, right) => left.label.localeCompare(right.label))
	.map((category) => ({
		...category,
		entryCount: getEntriesForCategory(category.id).length,
	}));
---

<BaseLayout title="Archives - Cameron's Thoughts" shellWidth="wide">
	<div class="archive-shell">
		<h1 class="surface-heading">Archives</h1>
		<div class="archive-grid">
			<section class="surface-card">
				<div class="surface-pad">
					<div class="flow-stack" data-gap="3">
						<h2 class="archive-section__heading">By year</h2>
						<ul class="archive-list" role="list">
							{years.map((year) => (
								<li class="archive-list__item">
									<a class="archive-list__link" href={`/${year}`}>
										<span>{year}</span>
										<span class="ui-badge">{getEntriesForYear(year).length}</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			</section>
			<section class="surface-card">
				<div class="surface-pad">
					<div class="flow-stack" data-gap="3">
						<h2 class="archive-section__heading">By category</h2>
						<ul class="archive-list" role="list">
							{categories.map((category) => (
								<li class="archive-list__item">
									<a class="archive-list__link" href={`/cat/${category.basename}`}>
										<span>{category.label}</span>
										<span class="ui-badge">{category.entryCount}</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			</section>
		</div>
	</div>
</BaseLayout>
