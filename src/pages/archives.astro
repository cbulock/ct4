---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
	getCategories,
	getEntriesForCategory,
	getEntriesForYear,
	getEntryYears,
} from '../lib/content';

const years = (await getEntryYears()).slice().reverse();
const categories = await Promise.all(
	getCategories()
	.slice()
	.sort((left, right) => left.label.localeCompare(right.label))
	.map(async (category) => ({
		...category,
		entryCount: (await getEntriesForCategory(category.id)).length,
	})),
);
const entriesPerYear = new Map(
	await Promise.all(
		years.map(async (year) => [year, (await getEntriesForYear(year)).length]),
	),
);
---

<BaseLayout title="Archives - Cameron's Thoughts" shellWidth="wide">
	<div class="archive-shell">
		<h1 class="surface-heading">Archives</h1>
		<div class="archive-grid">
			<cindor-card>
				<div class="surface-pad">
					<cindor-stack gap="3">
						<h2 class="archive-section__heading">By year</h2>
						<ul class="archive-list" role="list">
							{years.map((year) => (
								<li class="archive-list__item">
									<a class="archive-list__link" href={`/${year}`}>
										<span>{year}</span>
										<cindor-badge>{entriesPerYear.get(year)}</cindor-badge>
									</a>
								</li>
							))}
						</ul>
					</cindor-stack>
				</div>
			</cindor-card>
			<cindor-card>
				<div class="surface-pad">
					<cindor-stack gap="3">
						<h2 class="archive-section__heading">By category</h2>
						<ul class="archive-list" role="list">
							{categories.map((category) => (
								<li class="archive-list__item">
									<a class="archive-list__link" href={`/cat/${category.basename}`}>
										<span>{category.label}</span>
										<cindor-badge>{category.entryCount}</cindor-badge>
									</a>
								</li>
							))}
						</ul>
					</cindor-stack>
				</div>
			</cindor-card>
		</div>
	</div>
</BaseLayout>
