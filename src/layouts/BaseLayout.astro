---
import 'cindor-ui-core/styles.css';
import '../styles/global.css';
import Search from '../components/Search.astro';

const { title = "Cameron's Thoughts", shellWidth = 'default' } = Astro.props;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#ffffff" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5" />
		<meta name="msapplication-TileColor" content="#da532c" />
		<script is:inline>
			(() => {
				const root = document.documentElement;
				const primaryColor = '#425664';
				const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = isDark ? 'dark' : 'light';
				const parseHexColor = (value) => {
					const hex = value.replace('#', '').trim();
					if (!/^[0-9a-f]{6}$/i.test(hex)) {
						return null;
					}

					return {
						red: Number.parseInt(hex.slice(0, 2), 16),
						green: Number.parseInt(hex.slice(2, 4), 16),
						blue: Number.parseInt(hex.slice(4, 6), 16),
					};
				};
				const clampChannel = (value) => Math.min(255, Math.max(0, Math.round(value)));
				const mixColors = (source, target, amount) => ({
					red: clampChannel(source.red + (target.red - source.red) * amount),
					green: clampChannel(source.green + (target.green - source.green) * amount),
					blue: clampChannel(source.blue + (target.blue - source.blue) * amount),
				});
				const formatHexColor = (color) =>
					`#${color.red.toString(16).padStart(2, '0')}${color.green
						.toString(16)
						.padStart(2, '0')}${color.blue.toString(16).padStart(2, '0')}`;
				const getRelativeLuminance = (color) => {
					const channels = [color.red, color.green, color.blue].map((channel) => {
						const normalized = channel / 255;
						return normalized <= 0.04045
							? normalized / 12.92
							: ((normalized + 0.055) / 1.055) ** 2.4;
					});

					return 0.2126 * channels[0] + 0.7152 * channels[1] + 0.0722 * channels[2];
				};
				const getContrastRatio = (firstLuminance, secondLuminance) => {
					const lighter = Math.max(firstLuminance, secondLuminance);
					const darker = Math.min(firstLuminance, secondLuminance);
					return (lighter + 0.05) / (darker + 0.05);
				};
				const chooseReadableForeground = (color) => {
					const luminance = getRelativeLuminance(color);
					const whiteContrast = getContrastRatio(luminance, 1);
					const blackContrast = getContrastRatio(luminance, 0);
					return whiteContrast >= blackContrast ? '#ffffff' : '#0f0e0c';
				};
				const baseColor = parseHexColor(primaryColor);

				root.setAttribute('data-theme', theme);
				root.style.colorScheme = theme;

				if (!baseColor) {
					return;
				}

				const white = { red: 255, green: 255, blue: 255 };
				const black = { red: 0, green: 0, blue: 0 };
				const accent = isDark ? mixColors(baseColor, white, 0.18) : baseColor;
				const hover = isDark ? mixColors(baseColor, white, 0.36) : mixColors(baseColor, black, 0.18);
				const press = isDark ? mixColors(baseColor, white, 0.54) : mixColors(baseColor, black, 0.32);
				const accentForeground = chooseReadableForeground(accent);

				root.style.setProperty('--accent', formatHexColor(accent));
				root.style.setProperty('--accent-hover', formatHexColor(hover));
				root.style.setProperty('--accent-press', formatHexColor(press));
				root.style.setProperty(
					'--accent-muted',
					isDark
						? `rgba(${accent.red}, ${accent.green}, ${accent.blue}, 0.16)`
						: formatHexColor(mixColors(baseColor, white, 0.86)),
				);
				root.style.setProperty('--accent-fg', accentForeground);
				root.style.setProperty('--fg-on-accent', accentForeground);
				root.style.setProperty('--ring-focus', `0 0 0 2px ${formatHexColor(accent)}`);
			})();
		</script>
		<title>{title}</title>
		<script>
			import 'cindor-ui-core/register';
		</script>
	</head>
	<body>
		<cindor-provider
			theme="system"
			theme-family="default"
			primary-color="#425664"
		>
			<div class="site-shell">
				<cindor-layout>
					<cindor-layout-header>
						<div class="site-shell__masthead">
							<div class="site-shell__masthead-inner">
								<div class="masthead-row">
									<a class="site-brand" href="/">Cameron&apos;s Thoughts</a>
									<div class="masthead-actions">
										<Search />
										<cindor-link class="site-nav-link" href="/archives">Archives</cindor-link>
									</div>
								</div>
							</div>
						</div>
					</cindor-layout-header>
					<cindor-layout-content>
						<div class:list={['page-shell__inner', shellWidth === 'wide' && 'page-shell__inner--wide']}>
							<slot />
							<footer class="site-footer">
								<p>{`©2003-${currentYear} Cameron Bulock`}</p>
							</footer>
						</div>
					</cindor-layout-content>
				</cindor-layout>
			</div>
		</cindor-provider>
	</body>
</html>
